COMPOSE_PROJECT_NAME=squirrel

# EPICS Server DNS Mappings
# Required for Docker Desktop on macOS/Windows where containers can't access
# the host's DNS servers. Get IPs with: host <hostname>
# Format: hostname:ip_address

EPICS_HOST_PROD=your-epics-server:xxx.xxx.xxx.xxx
EPICS_HOST_DMZ=your-dmz-server:xxx.xxx.xxx.xxx
